generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Re-export the same models as the root schema so the mini-service has its
// own generated client. We keep this as a copy to avoid relative path
// surprises; the source of truth remains ../../prisma/schema.prisma.

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  avatarColor     String   @default("#6366f1")
  githubUsername  String?
  passwordHash    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  boardMemberships BoardMember[]
  assignedCards    Card[]        @relation("CardAssignee")
  createdCards     Card[]        @relation("CardCreator")
  comments         Comment[]
  activities       Activity[]
  timeEntries      TimeEntry[]
}

model BoardMember {
  id      String   @id @default(cuid())
  boardId String
  userId  String
  role    String   @default("member")
  joinedAt DateTime @default(now())

  board  Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user   User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model Board {
  id            String   @id @default(cuid())
  name          String
  description   String?
  sprintStart   DateTime?
  sprintEnd     DateTime?
  template      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members  BoardMember[]
  columns  Column[]
  cards    Card[]
  labels   Label[]
  insights AIInsight[]
  digests  Digest[]

  @@index([updatedAt])
}

model Column {
  id        String  @id @default(cuid())
  boardId   String
  name      String
  order     Int
  color     String  @default("#64748b")
  wipLimit  Int?
  isDone    Boolean @default(false)

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards Card[]

  @@index([boardId])
}

model Card {
  id                  String    @id @default(cuid())
  boardId             String
  columnId            String
  title               String
  description         String?
  order               Int
  complexity          Int?
  complexityAccepted  Boolean   @default(false)
  dueDate             DateTime?
  githubIssueNumber   Int?
  githubRepo          String?
  sourceUrl           String?
  version             Int       @default(1)
  lastEditedBy        String?
  lastEditedAt        DateTime?
  timeLoggedSec       Int       @default(0)
  timerStartedAt      DateTime?

  assigneeId String?
  creatorId  String?

  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column  Column  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee User?  @relation("CardAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User?  @relation("CardCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  labels      CardLabel[]
  comments    Comment[]
  activities  Activity[]
  history     CardHistory[]
  timeEntries TimeEntry[]
  dependenciesAsBlocker CardDependency[] @relation("BlockerCard")
  dependenciesAsBlocked CardDependency[] @relation("BlockedCard")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  completedAt DateTime?

  @@index([boardId])
  @@index([columnId])
  @@index([assigneeId])
  @@index([boardId, githubRepo, githubIssueNumber])
}

model Label {
  id      String @id @default(cuid())
  boardId String
  name    String
  color   String @default("#64748b")

  board Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards CardLabel[]

  @@unique([boardId, name])
}

model CardLabel {
  cardId  String
  labelId String

  card  Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model Comment {
  id        String   @id @default(cuid())
  cardId    String
  userId    String
  text      String
  createdAt DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
}

model Activity {
  id        String   @id @default(cuid())
  cardId    String
  boardId   String
  userId    String
  type      String
  summary   String
  metadata  String?
  createdAt DateTime @default(now())

  card  Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@index([cardId])
}

model CardDependency {
  id           String @id @default(cuid())
  blockerId    String
  blockedId    String
  createdAt    DateTime @default(now())

  blocker Card @relation("BlockerCard", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked Card @relation("BlockedCard", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  cardId      String
  userId      String
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  createdAt   DateTime  @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([cardId])
  @@index([userId])
}

model AIInsight {
  id        String   @id @default(cuid())
  boardId   String
  type      String
  severity  String   @default("info")
  title     String
  message   String
  metadata  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
  @@index([boardId, type])
}

model Digest {
  id        String   @id @default(cuid())
  boardId   String
  weekStart DateTime
  weekEnd   DateTime
  content   String
  createdAt DateTime @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, weekStart])
}

model CardHistory {
  id                 String   @id @default(cuid())
  cardId             String
  boardId            String
  action             String
  fromColumnId       String?
  toColumnId         String?
  assigneeId         String?
  complexity         Int?
  labelNames         String?
  descriptionLength  Int?
  daysToComplete     Int?
  createdAt          DateTime @default(now())

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([boardId])
  @@index([cardId])
}
